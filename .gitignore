# .gitignore

# ── 절대 올리면 안 되는 파일 ──
.env
.env.*
*.pem
*.ppk
secrets/
*secret*
*password*
*credential*

# ── 백엔드 빌드 결과물 ──
backend/build/
backend/.gradle/
backend/out/
*.class
*.jar
!backend/gradle/wrapper/gradle-wrapper.jar

# ── 프론트엔드 빌드 결과물 ──
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── IDE ──
.idea/
*.iml
.vscode/
*.swp
*.swo

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── 로그 ──
*.log
logs/
